# Copia este archivo a ".env" y ajusta los valores en tu servidor.
# (o exporta estas variables en el sistema / servicio systemd)

# Puerto donde escucha la API
PORT=3001

# Cada cuántos minutos se actualizan los datos del WMS
REFRESH_MIN=30

# Conexión al WMS
WMS_BASE=https://fisfiberwms.duckdns.org
WMS_EMAIL=ymontoya@fisfiber.com.mx
WMS_PASS=7895

# Token opcional para proteger POST /api/refrescar (déjalo vacío en red interna)
REFRESH_TOKEN=

# Archivo donde se guarda el último dato bueno (sobrevive reinicios)
CACHE_FILE=cache.json
