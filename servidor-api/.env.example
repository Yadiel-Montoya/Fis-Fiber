# Copia este archivo a ".env" y ajusta los valores en tu servidor.
# (o exporta estas variables en el sistema / servicio systemd)

# Puerto donde escucha la API
PORT=3001

# Cada cuántos minutos se actualizan los datos del WMS
REFRESH_MIN=30

# Conexión al WMS
WMS_BASE=https://fisfiberwms.duckdns.org
WMS_EMAIL=ymontoya@fisfiber.com.mx
WMS_PASS=7895

# Token opcional para proteger POST /api/refrescar (déjalo vacío en red interna)
REFRESH_TOKEN=

# Archivo donde se guarda el último dato bueno (sobrevive reinicios)
CACHE_FILE=cache.json

# ── SAP Business One (Almacén Materia Prima) ──
# Déjalo vacío si aún no lo conectas. Usa un usuario de SOLO LECTURA.
SAP_ENGINE=mssql                 # mssql  o  hana
SAP_HOST=                        # ej. 192.168.1.10  o  192.168.1.10\SQLEXPRESS
SAP_PORT=                        # mssql: 1433 (opcional) · hana: 30015
SAP_DB=                          # ej. SBO_FISFIBER
SAP_USER=                        # usuario de solo lectura de la BD
SAP_PASS=
# Solo SQL Server: nombre del driver ODBC instalado
SAP_ODBC_DRIVER=ODBC Driver 17 for SQL Server
